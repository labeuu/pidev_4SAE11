# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Docker Hub
DOCKER_HUB_USERNAME=your-dockerhub-username
TAG=latest

# MySQL
MYSQL_ROOT_PASSWORD=change-me-strong-password

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin-password
KEYCLOAK_ADMIN_CLIENT_SECRET=smart-freelance-internal-secret
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/smart-freelance
KEYCLOAK_JWKS_URI=http://keycloak:8080/realms/smart-freelance/protocol/openid-connect/certs
# Keycloak uses hostname "keycloak" inside Docker so JWT issuer matches all microservices.
# If the admin console redirects incorrectly in the browser, add this line to your hosts file:
#   127.0.0.1 keycloak

# Email (Mailtrap or real SMTP)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

# External API keys
AI_API_KEY=
GITHUB_TOKEN=

# Ollama (pulled on first stack start by ollama-model-init; use a tag from https://ollama.com/library )
OLLAMA_MODEL=gemma2:2b

# Credential file paths (host paths mounted into containers)
# Firebase: required for notification microservice (Firestore). Do not commit the real JSON.
FIREBASE_CREDENTIALS=./firebase-credentials/firebase-credentials.json
PLANNING_CALENDAR_CREDENTIALS=./credentials/calendar-service-account.json
MEETING_CALENDAR_CREDENTIALS=./credentials/meeting-service-account.json
  
# ── Monitoring (Prometheus + Grafana) ─────────────────────────────────────────
# Grafana admin credentials (change before deploying anywhere public)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
