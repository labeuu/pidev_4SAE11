# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Docker Hub
DOCKER_HUB_USERNAME=your-dockerhub-username
TAG=latest

# MySQL
MYSQL_ROOT_PASSWORD=change-me-strong-password

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin-password
KEYCLOAK_ADMIN_CLIENT_SECRET=smart-freelance-internal-secret
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# Email (Mailtrap or real SMTP)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=

# External API keys
AI_API_KEY=
GITHUB_TOKEN=

# Credential file paths (host paths mounted into containers)
FIREBASE_CREDENTIALS=./firebase-credentials/firebase-credentials.json
PLANNING_CALENDAR_CREDENTIALS=./credentials/calendar-service-account.json
MEETING_CALENDAR_CREDENTIALS=./credentials/meeting-service-account.json
