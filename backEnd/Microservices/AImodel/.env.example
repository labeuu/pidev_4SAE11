OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# Axios wait for Ollama (default 2h in code for slow local LLM)
OLLAMA_TIMEOUT_MS=14400000
# Fast probe for live status (GET /api/tags)
OLLAMA_STATUS_TIMEOUT_MS=5000
PORT=8095

# Eureka (set EUREKA_ENABLED=false to run without the registry)
EUREKA_ENABLED=true
EUREKA_SERVER_URL=http://localhost:8420/eureka
EUREKA_APP_NAME=AIMODEL
EUREKA_INSTANCE_HOSTNAME=localhost
EUREKA_INSTANCE_IP=127.0.0.1
EUREKA_RENEWAL_INTERVAL_SECS=30
EUREKA_DURATION_SECS=90
