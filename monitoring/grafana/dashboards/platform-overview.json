{
  "__inputs": [],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Smart Freelance Platform — service health and JVM overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red",   "index": 0, "text": "DOWN"  },
                           "1": { "color": "green", "index": 1, "text": "UP"    } },
              "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",   "value": null },
            { "color": "green", "value": 1    }
          ]},
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode":   "background",
        "graphMode":   "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode":    "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":    "up{job=~\"sf_.*\"}",
          "instant": true,
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ],
      "title": "Service Status (UP / DOWN)",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "HTTP Traffic",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "sum by (application) (rate(http_server_requests_seconds_count[2m]))",
          "legendFormat": "{{ application }}",
          "refId":        "A"
        }
      ],
      "title": "HTTP Request Rate (req/s) by Service",
      "type":  "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 3,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "histogram_quantile(0.99, sum by (application, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p99 {{ application }}",
          "refId":        "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "histogram_quantile(0.50, sum by (application, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "p50 {{ application }}",
          "refId":        "B"
        }
      ],
      "title": "HTTP Latency (p50 / p99) by Service",
      "type":  "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 4,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "sum by (application) (rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / sum by (application) (rate(http_server_requests_seconds_count[5m]))",
          "legendFormat": "{{ application }}",
          "refId":        "A"
        }
      ],
      "title": "HTTP 5xx Error Rate by Service",
      "type":  "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "JVM Memory",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 5,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{ application }} heap used",
          "refId":        "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "{{ application }} heap max",
          "refId":        "B"
        }
      ],
      "title": "JVM Heap Usage",
      "type":  "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.7  },
            { "color": "red",    "value": 0.9  }
          ]},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 6,
      "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "jvm_memory_used_bytes{area=\"heap\"} / jvm_memory_max_bytes{area=\"heap\"}",
          "instant":      true,
          "legendFormat": "{{ application }}",
          "refId":        "A"
        }
      ],
      "title": "Heap Usage % per Service",
      "type":  "gauge"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "JVM Threads & GC",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 7,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "jvm_threads_live_threads",
          "legendFormat": "{{ application }} live",
          "refId":        "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "jvm_threads_daemon_threads",
          "legendFormat": "{{ application }} daemon",
          "refId":        "B"
        }
      ],
      "title": "JVM Thread Count",
      "type":  "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 8,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "rate(jvm_gc_pause_seconds_sum[5m]) / rate(jvm_gc_pause_seconds_count[5m])",
          "legendFormat": "{{ application }} avg GC pause",
          "refId":        "A"
        }
      ],
      "title": "Average GC Pause Duration",
      "type":  "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Database Connection Pools",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 9,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "hikaricp_connections_active",
          "legendFormat": "{{ application }} active",
          "refId":        "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "hikaricp_connections_idle",
          "legendFormat": "{{ application }} idle",
          "refId":        "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "hikaricp_connections_max",
          "legendFormat": "{{ application }} max",
          "refId":        "C"
        }
      ],
      "title": "HikariCP Connection Pool",
      "type":  "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 10,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "histogram_quantile(0.99, rate(hikaricp_connections_acquisition_seconds_bucket[5m]))",
          "legendFormat": "{{ application }} p99 acquisition",
          "refId":        "A"
        }
      ],
      "title": "HikariCP Connection Acquisition Time (p99)",
      "type":  "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "id": 105,
      "title": "CPU & System",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "max": 1, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 },
      "id": 11,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "process_cpu_usage",
          "legendFormat": "{{ application }} process CPU",
          "refId":        "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "system_cpu_usage",
          "legendFormat": "{{ application }} system CPU",
          "refId":        "B"
        }
      ],
      "title": "CPU Usage",
      "type":  "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red",   "value": 1    }
          ]},
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 50 },
      "id": 12,
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "count(up{job=~\"sf_.*\"} == 0) or vector(0)",
          "instant":      true,
          "legendFormat": "Services Down",
          "refId":        "A"
        }
      ],
      "title": "Total Services Currently DOWN",
      "type":  "stat"
    }

  ],
  "refresh":        "30s",
  "schemaVersion":  38,
  "tags":           ["spring-boot", "smart-freelance", "microservices"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(up{job=~\"sf_.*\"}, service)",
        "hide":    0,
        "includeAll": true,
        "multi":   true,
        "name":    "service",
        "options": [],
        "query": {
          "query": "label_values(up{job=~\"sf_.*\"}, service)",
          "refId": "StandardVariableQuery"
        },
        "refresh":  2,
        "sort":     1,
        "type":     "query",
        "label":    "Service"
      }
    ]
  },
  "time":      { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone":  "browser",
  "title":     "Smart Freelance — Platform Overview",
  "uid":       "sf-platform-overview",
  "version":   1
}
